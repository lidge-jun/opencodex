---
// Landing page shared by the three locales. Liquid Editorial composition:
// type-led centered hero, provider pill chips as content, product-as-stage
// media band, quickstart terminal, bento feature slab, docs link row.
// Styling lives in src/styles/custom.css under the `.lp` namespace.
import { Image } from 'astro:assets';
import {
	siAnthropic,
	siDeepseek,
	siGoogle,
	siMoonshotai,
	siOllama,
	siOpenrouter,
} from 'simple-icons';
import demo from '../assets/demo.gif';
import dashboard from '../assets/dashboard.png';
import picker from '../assets/codex-app-picker.png';
import heroFieldLight from '../assets/hero-route-light.png';
import heroFieldDark from '../assets/hero-route-dark.png';

interface Props {
	locale?: 'ko' | 'zh-cn' | 'ru' | 'ja';
}
const { locale } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const prefix = locale ? `${base}${locale}/` : base;

const t = (en: string, ko: string, zh: string, ru: string, ja: string) =>
	locale === 'ko' ? ko : locale === 'zh-cn' ? zh : locale === 'ru' ? ru : locale === 'ja' ? ja : en;

const icons: Record<string, string> = {
	// Lucide outline paths (24x24, stroke)
	plug: 'M12 22v-5M9 8V2M15 8V2M6 8h12l-1 6a5 5 0 0 1-10 0Z',
	key: 'M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777Zm0 0L15.5 7.5m0 0 3 3L22 7l-3-3m-3.5 3.5L19 4',
	users: 'M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm13 10v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75',
	picker: 'M3 5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2Zm6-2v18M3 9h6',
	bot: 'M12 8V4H8m8 0h-4M4 12a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2Zm11 3h.01M9 15h.01M2 14h2m16 0h2',
	search: 'M11 19a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm10 2-4.35-4.35',
	rocket: 'M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09ZM12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2Zm-3-3H4s.55-3.03 2-4c1.62-1.08 5 0 5 0m0 9v5s3.03-.55 4-2c1.08-1.62 0-5 0-5',
	book: 'M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20',
	code: 'M16 18l6-6-6-6M8 6l-6 6 6 6',
	terminal: 'M4 17l6-6-6-6M12 19h8',
	folder: 'M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z',
};

// Official monochrome marks from simple-icons where the brand exists in the
// library; brands missing from it stay text-only (no generic substitutes).
const providers: { label: string; path?: string }[] = [
	{ label: 'Anthropic', path: siAnthropic.path },
	{ label: 'Google', path: siGoogle.path },
	{ label: 'xAI' },
	{ label: 'Kimi', path: siMoonshotai.path },
	{ label: 'Ollama Cloud', path: siOllama.path },
	{ label: 'Groq' },
	{ label: 'OpenRouter', path: siOpenrouter.path },
	{ label: 'Azure' },
	{ label: 'DeepSeek', path: siDeepseek.path },
	{ label: 'GLM' },
];

const quickstartMini = [
	{ cmd: 'npm install -g @bitkyc08/opencodex', note: t('Install', '설치', '安装', 'Установка', 'インストール') },
	{ cmd: 'ocx start', note: t('Start the proxy', '프록시 시작', '启动代理', 'Запуск прокси', 'プロキシを起動') },
];

const quickstart = [
	{ cmd: 'npm install -g @bitkyc08/opencodex', note: t('Install', '설치', '安装', 'Установка', 'インストール') },
	{ cmd: 'ocx init', note: t('Inject a provider into Codex', 'Codex에 프로바이더 주입', '向 Codex 注入 provider', 'Внедрение провайдера в Codex', 'プロバイダーを Codex に注入') },
	{ cmd: 'ocx start', note: t('Start the proxy', '프록시 시작', '启动代理', 'Запуск прокси', 'プロキシを起動') },
	{ cmd: 'codex "Write a hello world in Rust"', note: t('Codex now routes through ocx', 'Codex가 ocx를 경유', 'Codex 现在经由 ocx 路由', 'Codex теперь работает через ocx', 'Codex は ocx 経由に') },
];

// full docs map for the closing sitemap band (also the mobile path to every section)
const docsMap = [
	{
		label: t('Getting Started', '시작하기', '开始使用', 'Начало работы', 'はじめに'),
		icon: 'rocket',
		links: [
			{ label: t('Installation', '설치', '安装', 'Установка', 'インストール'), href: `${prefix}getting-started/installation/` },
			{ label: t('Quickstart', '빠른 시작', '快速开始', 'Быстрый старт', 'クイックスタート'), href: `${prefix}getting-started/quickstart/` },
			{ label: t('How It Works', '동작 원리', '工作原理', 'Как это работает', '仕組み'), href: `${prefix}getting-started/how-it-works/` },
		],
	},
	{
		label: t('Guides', '가이드', '指南', 'Руководства', 'ガイド'),
		icon: 'book',
		links: [
			{ label: t('Providers', '프로바이더', '提供商', 'Провайдеры', 'プロバイダー'), href: `${prefix}guides/providers/` },
			{ label: t('Model Routing', '모델 라우팅', '模型路由', 'Маршрутизация моделей', 'モデルルーティング'), href: `${prefix}guides/model-routing/` },
			{ label: t('Codex Integration', 'Codex 통합', 'Codex 集成', 'Интеграция с Codex', 'Codex 連携'), href: `${prefix}guides/codex-integration/` },
			{ label: t('Codex App Model Picker', 'Codex App 모델 선택기', 'Codex App 模型选择器', 'Селектор моделей Codex App', 'Codex App モデルピッカー'), href: `${prefix}guides/codex-app-models/` },
			{ label: 'Claude Code', href: `${prefix}guides/claude-code/` },
			{ label: t('Sidecars: Search & Vision', '사이드카: 검색 & 비전', '边车：搜索与视觉', 'Сайдкары: поиск и зрение', 'サイドカー: 検索 & ビジョン'), href: `${prefix}guides/sidecars/` },
			{ label: t('Web Dashboard', '웹 대시보드', '网页控制台', 'Веб-дашборд', 'ウェブダッシュボード'), href: `${prefix}guides/web-dashboard/` },
			{ label: t('Sub-agent Surface', '서브에이전트 서피스', '子代理界面', 'Интерфейс подагентов', 'サブエージェントサーフェス'), href: `${prefix}guides/sub-agent-surface/` },
		],
	},
	{
		label: t('Reference', '레퍼런스', '参考', 'Справочник', 'リファレンス'),
		icon: 'code',
		links: [
			{ label: 'CLI', href: `${prefix}reference/cli/` },
			{ label: t('Configuration', '설정', '配置', 'Конфигурация', '設定'), href: `${prefix}reference/configuration/` },
			{ label: t('Adapters', '어댑터', '适配器', 'Адаптеры', 'アダプター'), href: `${prefix}reference/adapters/` },
			{ label: t('Architecture', '아키텍처', '架构', 'Архитектура', 'アーキテクチャ'), href: `${prefix}reference/architecture/` },
		],
	},
	{
		label: t('Project', '프로젝트', '项目', 'Проект', 'プロジェクト'),
		icon: 'folder',
		links: [
			{ label: t('Contributing', '기여하기', '贡献', 'Участие в проекте', 'コントリビュート'), href: `${prefix}contributing/` },
			{ label: 'GitHub', href: 'https://github.com/lidge-jun/opencodex' },
			{ label: 'npm', href: 'https://www.npmjs.com/package/@bitkyc08/opencodex' },
		],
	},
];
---

<div class="lp not-content">
	<!-- scene stack: hero -> quickstart -> horizontal rail. Each wrapper owns a
	     named view-timeline; its sticky inner stage pins under the pill header
	     while the next scene rides over it (motion.md sticky stacking +
	     scale-depth morph). -->
	<div class="lp-scenes">
	<section class="lp-scene lp-scene-hero">
	<div class="lp-scene-inner lp-hero-field">
		<div class="lp-field-bg" aria-hidden="true">
			<Image src={heroFieldLight} alt="" class="lp-field-light" loading="eager" widths={[1024, 2048]} sizes="100vw" />
			<Image src={heroFieldDark} alt="" class="lp-field-dark" loading="lazy" widths={[1024, 2048]} sizes="100vw" />
		</div>
		<div class="lp-hero-copy">
			{/* Product-word drum: the H1 performs the claim — the proxy serves both
			    Codex and Claude Code. 4-face rotateX cylinder, fixed slot width via
			    inline-grid stacking; reduced-motion collapses to a static pairing. */}
			<h1 id="_top">
				{t('Run ', '', '让 ', 'Запускайте ', '実行 ')}<span class="lp-drum" aria-label="Codex and Claude">
					<span class="lp-drum-spin" aria-hidden="true">
						<span class="lp-drum-face lp-drum-codex">Codex</span>
						<span class="lp-drum-face lp-drum-claude">Claude</span>
						<span class="lp-drum-face lp-drum-codex">Codex</span>
						<span class="lp-drum-face lp-drum-claude">Claude</span>
					</span>
					<span class="lp-drum-static" aria-hidden="true">Codex<span class="lp-drum-dot"> · </span>Claude</span>
				</span>{t(' on any LLM.', '를 어떤 LLM 위에서든.', ' 跑在任意 LLM 上。', ' на любой LLM.', ' を任意の LLM 上で。')}
			</h1>
			<p class="lp-sub">
				{t('opencodex is a local proxy that serves Codex and Claude Code from one port — translating each wire format to any provider, with streaming, tool calls, reasoning, and images in both directions. Zero client patches.', 'opencodex는 포트 하나로 Codex와 Claude Code를 함께 서빙하는 로컬 프록시입니다 — 각 wire 포맷을 어떤 프로바이더로든 양방향 변환하고, 스트리밍·tool call·reasoning·이미지까지 그대로 통과시킵니다. 클라이언트 패치는 없습니다.', 'opencodex 是一个本地代理，用同一个端口同时服务 Codex 与 Claude Code —— 将各自的线路格式双向翻译为任意 provider，支持流式、工具调用、推理与图像。无需修补客户端。', 'opencodex — локальный прокси, который обслуживает Codex и Claude Code через один порт: транслирует каждый wire-формат под любого провайдера, пропуская стриминг, вызовы инструментов, рассуждения и изображения в обе стороны. Никаких патчей на стороне клиента.', 'opencodex は 1 つのポートで Codex と Claude Code をまとめて提供するローカルプロキシです — 各 wire フォーマットを任意のプロバイダーへ双方向に変換し、ストリーミング・ツール呼び出し・推論・画像までそのまま通します。クライアントのパッチは不要です。')}
			</p>
			<div class="lp-cta">
				<a class="lp-btn-primary" href={`${prefix}getting-started/installation/`}>
					{t('Get Started', '시작하기', '快速开始', 'Начать', 'はじめに')}
					<svg viewBox="0 0 16 16" width="14" height="14" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
				</a>
				<a class="lp-btn-ghost" href="https://github.com/lidge-jun/opencodex">GitHub</a>
			</div>
		<ul class="lp-chips" aria-label={t('Supported providers', '지원 프로바이더', '支持的 provider', 'Поддерживаемые провайдеры', '対応プロバイダー')}>
				{providers.map((p) => (
					<li>
						{p.path && (
							<svg class="lp-chip-mark" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
								<path d={p.path} />
							</svg>
						)}
						{p.label}
					</li>
				))}
				<li class="lp-chip-more"><a href={`${prefix}guides/providers/`}>{t('40+ providers', '프로바이더 40+', '40+ providers', '40+ провайдеров', '40+ プロバイダー')}</a></li>
			</ul>
		</div>
		<div class="lp-stage-in">
			<Image src={dashboard} alt={t('The opencodex dashboard — live proxy status, routed providers, and available models', 'opencodex 대시보드 — 실시간 프록시 상태, 라우팅된 프로바이더, 사용 가능한 모델', 'opencodex 控制台 —— 实时代理状态、路由的 provider 与可用模型', 'Дашборд opencodex — статус прокси в реальном времени, маршрутизированные провайдеры и доступные модели', 'opencodex ダッシュボード — プロキシのリアルタイム状態、ルーティング済みプロバイダー、利用可能モデル')} loading="eager" />
		</div>
	</div>
	</section>

	<!-- quickstart sheet scene -->
	<section class="lp-scene lp-scene-quick">
	<div class="lp-scene-inner lp-quick">
		<div class="lp-kinetic" aria-label={t('Install. Start. Codex, rerouted.', '설치. 시작. Codex는 그대로.', '安装。启动。Codex 即刻改道。', 'Установите. Запустите. Codex — по новому маршруту.', 'インストール。起動。Codex を経路変更。')}>
			<p class="lp-kline">{t('Install.', '설치.', '安装。', 'Установите.', 'インストール。')}</p>
			<p class="lp-kline">{t('Start.', '시작.', '启动。', 'Запустите.', '起動。')}</p>
			<p class="lp-kline lp-kline-accent">{t('Codex, rerouted.', 'Codex는 그대로.', 'Codex 即刻改道。', 'Codex — по новому маршруту.', 'Codex を経路変更。')}</p>
		</div>
		<div class="lp-quick-side">
			<div class="lp-terminal">
				<div class="lp-terminal-bar"><span>zsh</span></div>
				<pre>{quickstartMini.map((line) => (<code><span class="lp-prompt">$ </span>{line.cmd}<span class="lp-note">  # {line.note}</span>{'\n'}</code>))}</pre>
			</div>
			<a class="lp-inline-link" href={`${prefix}getting-started/quickstart/`}>{t('Full quickstart', '전체 퀵스타트', '完整快速开始', 'Полный быстрый старт', '完全なクイックスタート')} →</a>
		</div>
	</div>
	</section>

	<!-- demo scrub: the capture plays through, driven by scroll -->
	<section class="lp-scene lp-scene-scrub">
	<div class="lp-scene-inner lp-scrub">
		<h2 class="lp-scrub-title">{t('Watch Codex run on a routed model.', '라우팅된 모델 위의 Codex를 그대로.', '看 Codex 跑在路由模型上。', 'Смотрите, как Codex работает на маршрутизированной модели.', 'ルーティングされたモデルで動く Codex を見る。')}</h2>
		<div class="lp-scrub-stage">
			<canvas class="lp-scrub-canvas" data-base={base} data-count="158" width="960" height="856" aria-label={t('Codex App running a task on a routed non-OpenAI model', '라우팅된 비 OpenAI 모델에서 작업 중인 Codex App', 'Codex App 在路由的非 OpenAI 模型上执行任务', 'Codex App выполняет задачу на маршрутизированной модели не от OpenAI', 'ルーティングされた非 OpenAI モデルでタスクを実行する Codex App')}></canvas>
			<Image src={demo} alt={t('Codex App running a task on a routed non-OpenAI model', '라우팅된 비 OpenAI 모델에서 작업 중인 Codex App', 'Codex App 在路由的非 OpenAI 模型上执行任务', 'Codex App выполняет задачу на маршрутизированной модели не от OpenAI', 'ルーティングされた非 OpenAI モデルでタスクを実行する Codex App')} loading="lazy" class="lp-scrub-poster" />
		</div>
		<p class="lp-scrub-caption">{t('One task, streamed end to end through opencodex.', '작업 하나가 opencodex를 관통해 끝까지 스트리밍됩니다.', '一个任务，经 opencodex 全程流式完成。', 'Одна задача — стриминг через opencodex от начала до конца.', '1 つのタスクが opencodex を経てエンドツーエンドでストリーミングされます。')}</p>
	</div>
	</section>
	</div>

	<!-- feature bento: dominant cell + content-weighted spans -->
	<section class="lp-bento">
		<h2 class="lp-bento-title">{t('One proxy, the whole surface.', '프록시 하나로 전체 서피스를.', '一个代理，覆盖全部能力。', 'Один прокси — все возможности.', '1 つのプロキシでサーフェス全体を。')}</h2>
		<div class="lp-grid">
			<article class="lp-cell lp-cell-providers">
				<h3><svg class="lp-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={icons.plug} /></svg>{t('Any provider', '모든 프로바이더', '任意 provider', 'Любой провайдер', '任意のプロバイダー')}</h3>
				<p>
					{t('Five adapters cover Anthropic Messages, Google Gemini, Azure, the OpenAI Responses passthrough, and every OpenAI-compatible Chat Completions endpoint — 40+ built-in providers.', '어댑터 다섯 개가 Anthropic Messages, Google Gemini, Azure, OpenAI Responses passthrough, 그리고 모든 OpenAI 호환 Chat Completions 엔드포인트를 커버합니다 — 내장 프로바이더 40+.', '五个适配器覆盖 Anthropic Messages、Google Gemini、Azure、OpenAI Responses passthrough，以及所有 OpenAI 兼容的 Chat Completions 端点 —— 内置 40+ provider。', 'Пять адаптеров покрывают Anthropic Messages, Google Gemini, Azure, OpenAI Responses passthrough и любую OpenAI-совместимую конечную точку Chat Completions — 40+ встроенных провайдеров.', '5 つのアダプターが Anthropic Messages、Google Gemini、Azure、OpenAI Responses passthrough、そしてすべての OpenAI 互換 Chat Completions エンドポイントをカバーします — 組み込みプロバイダー 40+。')}
				</p>
			</article>
			<article class="lp-cell">
				<h3><svg class="lp-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={icons.key} /></svg>{t('OAuth or API key', 'OAuth 또는 API 키', 'OAuth 或 API key', 'OAuth или API-ключ', 'OAuth または API キー')}</h3>
				<p>{t('Log in with your xAI, Anthropic, or Kimi account — auto-refreshed — forward your ChatGPT login, or paste a key.', 'xAI, Anthropic, Kimi 계정으로 로그인(자동 갱신)하거나, ChatGPT 로그인을 포워딩하거나, 키를 붙여넣으세요.', '使用 xAI、Anthropic 或 Kimi 账号登录（自动刷新），转发 ChatGPT 登录，或粘贴 API key。', 'Войдите через аккаунт xAI, Anthropic или Kimi — с автообновлением, — пробросьте свой вход ChatGPT или просто вставьте ключ.', 'xAI、Anthropic、Kimi アカウントでログイン（自動更新）、ChatGPT ログインを転送、またはキーを貼り付け。')}</p>
			</article>
			<article class="lp-cell">
				<h3><svg class="lp-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={icons.users} /></svg>{t('ChatGPT account pool', 'ChatGPT 계정 풀', 'ChatGPT 账号池', 'Пул аккаунтов ChatGPT', 'ChatGPT アカウントプール')}</h3>
				<p>{t('Existing threads keep their account; new sessions auto-route to the lowest-usage healthy one after quota refresh.', '기존 thread는 계정을 유지하고, 새 세션은 할당량 갱신 후 사용량이 가장 낮은 정상 계정으로 자동 라우팅됩니다.', '已有 thread 保持原账号；新会话在刷新额度后自动路由到用量最低的健康账号。', 'Существующие треды сохраняют свой аккаунт; новые сессии после обновления квоты автоматически направляются на наименее загруженный работоспособный аккаунт.', '既存の thread はアカウントを維持し、新しいセッションは quota 更新後に使用量が最も低い健全なアカウントへ自動ルーティングされます。')}</p>
			</article>
			<article class="lp-cell lp-cell-picker">
