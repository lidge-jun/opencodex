<script>
	// Frame-sequence scrub (motion.md): the demo capture plays through as the
	// scrub scene scrolls. Short-circuits under reduced motion / small screens
	// (the animated poster stays); progressive checkpoint loading.
	const canvas = document.querySelector<HTMLCanvasElement>('.lp-scrub-canvas');
	const section = document.querySelector<HTMLElement>('.lp-scene-scrub');
	const poster = document.querySelector<HTMLImageElement>('.lp-scrub-poster');
	const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
	const wide = matchMedia('(min-width: 48rem)').matches;
	if (canvas && section && poster && !reduce && wide) {
		const ctx = canvas.getContext('2d');
		const count = Number(canvas.dataset.count || '0');
		const base = canvas.dataset.base || '/';
		const url = (i: number) => `${base}demo-frames/${String(i + 1).padStart(3, '0')}.webp`;
		const frames: (HTMLImageElement | undefined)[] = new Array(count);
		let started = false;
		let current = -1;
		let raf = 0;
		const load = (i: number) =>
			new Promise<void>((resolve) => {
				if (frames[i]) return resolve();
				const img = new Image();
				img.onload = () => { frames[i] = img; resolve(); };
				img.onerror = () => resolve();
				img.src = url(i);
			});
		const nearestLoaded = (i: number) => {
			for (let d = 0; d < count; d++) {
				if (frames[i - d]?.complete) return i - d;
				if (frames[i + d]?.complete) return i + d;
			}
			return -1;
		};
		const draw = (i: number) => {
			const j = nearestLoaded(Math.max(0, Math.min(count - 1, i)));
			if (j < 0 || j === current || !ctx) return;
			current = j;
			const img = frames[j]!;
			if (canvas.width !== img.naturalWidth) {
				canvas.width = img.naturalWidth;
				canvas.height = img.naturalHeight;
			}
			ctx.clearRect(0, 0, canvas.width, canvas.height);
			ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
			poster.style.display = 'none';
			canvas.style.display = 'block';
		};
		const update = () => {
			raf = 0;
			const rect = section.getBoundingClientRect();
			const travel = section.offsetHeight - innerHeight;
			if (travel <= 0) return;
			const progress = Math.min(1, Math.max(0, -rect.top / travel));
			draw(Math.round(progress * (count - 1)));
		};
		const start = async () => {
			if (started) return;
			started = true;
			await load(0);
			draw(0);
			// checkpoints first, then fill in idle time
			const checkpoints = [count - 1, Math.floor(count / 2), Math.floor(count / 4), Math.floor((3 * count) / 4)];
			await Promise.all(checkpoints.map(load));
			update();
			const fill = (i: number) => {
				if (i >= count) return;
				load(i).then(() => {
					const next = () => fill(i + 1);
					'requestIdleCallback' in window ? requestIdleCallback(next) : setTimeout(next, 16);
				});
			};
			fill(0);
			addEventListener('scroll', () => { raf ||= requestAnimationFrame(update); }, { passive: true });
			addEventListener('resize', () => { raf ||= requestAnimationFrame(update); }, { passive: true });
		};
		new IntersectionObserver((entries, obs) => {
			if (entries.some((e) => e.isIntersecting)) { obs.disconnect(); start(); }
		}, { rootMargin: '100% 0px' }).observe(section);
	}
</script>
