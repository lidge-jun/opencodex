---
// Custom Starlight header: default chrome (title / search / social) plus a
// desktop-only hover-dropdown nav and custom preference controls in the
// liquid-glass grammar.
// Mobile (<72rem) hides the nav; the built-in hamburger flow is untouched.
import { Icon } from '@astrojs/starlight/components';
import Search from '@astrojs/starlight/components/Search.astro';
import SiteTitle from '@astrojs/starlight/components/SiteTitle.astro';
import SocialIcons from '@astrojs/starlight/components/SocialIcons.astro';

const { locale } = Astro.locals.starlightRoute;
// Splash pages have no Starlight sidebar/hamburger, so the pill carries its own
// menu below the desktop-nav breakpoint.
const isSplash = Astro.locals.starlightRoute.entry.data.template === 'splash';
// Root locale is `undefined`; BASE_URL already ends with a slash.
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const prefix = locale ? `${base}${locale}/` : base;

type NavLink = { label: string; href: string };
type NavGroup = { label: string; links: NavLink[] };

const t = (en: string, ko: string, zh: string, ru: string, ja: string) =>
	locale === 'ko' ? ko : locale === 'zh-cn' ? zh : locale === 'ru' ? ru : locale === 'ja' ? ja : en;

type LanguageOption = { code: 'root' | 'ko' | 'zh-cn' | 'ru' | 'ja'; label: string };
const languages: LanguageOption[] = [
	{ code: 'root', label: 'English' },
	{ code: 'ko', label: '한국어' },
	{ code: 'zh-cn', label: '简体中文' },
	{ code: 'ru', label: 'Русский' },
	{ code: 'ja', label: '日本語' },
];
const currentLanguage = languages.find(({ code }) => code === (locale ?? 'root')) ?? languages[0];

// Preserve the current document path when switching locale. Starlight's root
// locale has no URL segment, while every translated locale does.
const routePrefix = locale ? `${base}${locale}/` : base;
const routeSuffix = Astro.url.pathname.startsWith(routePrefix)
	? Astro.url.pathname.slice(routePrefix.length)
	: '';
const languageHref = (code: LanguageOption['code']) =>
	`${code === 'root' ? base : `${base}${code}/`}${routeSuffix}`;

const themeLabels = {
	auto: t('Auto', '자동', '自动', 'Авто', '自動'),
	light: t('Light', '라이트', '浅色', 'Светлая', 'ライト'),
	dark: t('Dark', '다크', '深色', 'Тёмная', 'ダーク'),
};
const themeName = t('Theme', '테마', '主题', 'Тема', 'テーマ');
const themeCycleHint = t(
	'Click to use the next theme',
	'클릭하여 다음 테마로 전환',
	'点击切换到下一个主题',
	'Нажмите, чтобы включить следующую тему',
	'クリックして次のテーマに切り替え',
);

const groups: NavGroup[] = [
	{
		label: t('Getting Started', '시작하기', '开始使用', 'Начало работы', 'はじめに'),
		links: [
			{ label: t('Installation', '설치', '安装', 'Установка', 'インストール'), href: `${prefix}getting-started/installation/` },
			{ label: t('Quickstart', '빠른 시작', '快速开始', 'Быстрый старт', 'クイックスタート'), href: `${prefix}getting-started/quickstart/` },
			{ label: t('How It Works', '동작 원리', '工作原理', 'Как это работает', '仕組み'), href: `${prefix}getting-started/how-it-works/` },
		],
	},
	{
		label: t('Guides', '가이드', '指南', 'Руководства', 'ガイド'),
		links: [
			{ label: t('Providers', '프로바이더', '提供商', 'Провайдеры', 'プロバイダー'), href: `${prefix}guides/providers/` },
			{ label: t('Model Routing', '모델 라우팅', '模型路由', 'Маршрутизация моделей', 'モデルルーティング'), href: `${prefix}guides/model-routing/` },
			{ label: t('Codex Integration', 'Codex 통합', 'Codex 集成', 'Интеграция с Codex', 'Codex 連携'), href: `${prefix}guides/codex-integration/` },
			{ label: t('Codex App Model Picker', 'Codex App 모델 선택기', 'Codex App 模型选择器', 'Селектор моделей Codex App', 'Codex App モデルピッカー'), href: `${prefix}guides/codex-app-models/` },
			{ label: t('Sidecars: Search & Vision', '사이드카: 검색 & 비전', '边车：搜索与视觉', 'Сайдкары: поиск и зрение', 'サイドカー: 検索 & ビジョン'), href: `${prefix}guides/sidecars/` },
			{ label: t('Web Dashboard', '웹 대시보드', '网页控制台', 'Веб-дашборд', 'ウェブダッシュボード'), href: `${prefix}guides/web-dashboard/` },
			{ label: t('Sub-agent Surface', '서브에이전트 서피스', '子代理界面', 'Интерфейс подагентов', 'サブエージェントサーフェス'), href: `${prefix}guides/sub-agent-surface/` },
		],
	},
	{
		label: t('Reference', '레퍼런스', '参考', 'Справочник', 'リファレンス'),
		links: [
			{ label: 'CLI', href: `${prefix}reference/cli/` },
			{ label: t('Configuration', '설정', '配置', 'Конфигурация', '設定'), href: `${prefix}reference/configuration/` },
			{ label: t('Adapters', '어댑터', '适配器', 'Адаптеры', 'アダプター'), href: `${prefix}reference/adapters/` },
			{ label: t('Architecture', '아키텍처', '架构', 'Архитектура', 'アーキテクチャ'), href: `${prefix}reference/architecture/` },
		],
	},
];

const contributing: NavLink = {
	label: t('Contributing', '기여하기', '贡献', 'Участие в проекте', 'コントリビュート'),
	href: `${prefix}contributing/`,
};
---

<div class="header">
	<div class="title-wrapper sl-flex">
		<SiteTitle />
	</div>
	<nav class="glass-nav print:hidden" aria-label={t('Main', '주 메뉴', '主导航', 'Основная навигация', 'メイン')}>
		<ul>
			{
				groups.map((group, i) => (
					<li class="nav-item">
						<button type="button" class="nav-link" aria-haspopup="true" aria-expanded="false" aria-controls={`nav-drop-${i}`}>
							{group.label}
							<svg viewBox="0 0 16 16" width="10" height="10" fill="none" aria-hidden="true">
								<path d="M3.5 6l4.5 4.5L12.5 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
							</svg>
						</button>
						<div class="nav-drop" id={`nav-drop-${i}`}>
							<ul>
								{group.links.map((link) => (
									<li>
										<a href={link.href}>{link.label}</a>
									</li>
								))}
							</ul>
						</div>
					</li>
				))
			}
			<li class="nav-item">
				<a class="nav-link" href={contributing.href}>{contributing.label}</a>
			</li>
		</ul>
	</nav>
	<div class="sl-flex print:hidden search-wrapper">
		<Search />
	</div>
	<div class="sl-hidden md:sl-flex print:hidden right-group">
		<div class="sl-flex social-icons">
			<SocialIcons />
		</div>
		<div class="sl-flex header-preferences">
			{/*
				[Decision Log]
				- 목적과 의도: Keep theme switching one click away and make locale navigation visually consistent with the site's custom menus.
				- 기존 구현 및 제약 조건: Starlight's native selects inherit browser/OS popup styling and mouse focus borders that cannot match the glass design system.
				- 검토한 주요 대안: Restyle the native selects; replace both with popovers; cycle theme while keeping language as a popover.
				- 선택한 방식: Auto -> Light -> Dark theme cycle button plus a server-rendered language popover.
				- 다른 대안 대신 이 방식을 선택한 이유: Native option popups are not fully styleable, and theme has only three predictable states that do not need a menu.
				- 장점, 단점 및 영향: Consistent chrome and faster theme changes; the cycle order must remain stable and keyboard focus must remain visible.
			*/}
			<button
				type="button"
				class="preference-control theme-cycle"
				data-theme-value="auto"
				data-auto-label={themeLabels.auto}
				data-light-label={themeLabels.light}
				data-dark-label={themeLabels.dark}
				data-theme-name={themeName}
				data-cycle-hint={themeCycleHint}
				aria-label={`${themeName}: ${themeLabels.auto}. ${themeCycleHint}`}
				title={`${themeName}: ${themeLabels.auto}`}
			>
				<span class="preference-icon" data-theme-icon="auto"><Icon name="laptop" /></span>
				<span class="preference-icon" data-theme-icon="light" hidden><Icon name="sun" /></span>
				<span class="preference-icon" data-theme-icon="dark" hidden><Icon name="moon" /></span>
				<span data-theme-label>{themeLabels.auto}</span>
			</button>

			<div class="header-preference language-preference">
				<button
					type="button"
					class="preference-control language-trigger"
					aria-haspopup="menu"
					aria-expanded="false"
					aria-controls="language-menu"
					aria-label={t('Select language', '언어 선택', '选择语言', 'Выбрать язык', '言語を選択')}
				>
					<Icon name="translate" class="preference-icon" />
					<span>{currentLanguage.label}</span>
					<Icon name="down-caret" class="preference-caret" />
				</button>
				<div class="language-menu" id="language-menu" role="menu">
					<ul>
						{languages.map((language) => (
							<li>
								<a
									href={languageHref(language.code)}
									role="menuitemradio"
									aria-checked={language.code === (locale ?? 'root') ? 'true' : 'false'}
								>
									{language.label}
								</a>
							</li>
						))}
					</ul>
				</div>
			</div>
		</div>
	</div>
	{isSplash && (
		<div class="lp-menu print:hidden">
			<button
				type="button"
				class="lp-menu-btn"
				aria-haspopup="true"
				aria-expanded="false"
				aria-controls="lp-menu-panel"
				aria-label={t('Menu', '메뉴', '菜单', 'Меню', 'メニュー')}
			>
				<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
					<path d="M4 6h16M4 12h16M4 18h16" />
				</svg>
			</button>
			<div class="lp-menu-panel" id="lp-menu-panel">
				{groups.map((group) => (
					<div class="lp-menu-group">
						<span>{group.label}</span>
						<ul>
							{group.links.map((link) => (
								<li><a href={link.href}>{link.label}</a></li>
							))}
						</ul>
					</div>
				))}
				<a class="lp-menu-contrib" href={contributing.href}>{contributing.label}</a>
			</div>
		</div>
	)}
</div>

<style>
	.header {
		display: flex;
		gap: var(--sl-nav-gap);
		justify-content: space-between;
		align-items: center;
		height: 100%;
		/* floating glass pill, detached from the viewport edges */
		border-radius: var(--ocx-radius-pill, 999px);
		border: 1px solid var(--sl-color-hairline-light);
		background-color: var(--ocx-glass-rail, canvas);
		backdrop-filter: var(--ocx-glass-blur, blur(22px));
		-webkit-backdrop-filter: var(--ocx-glass-blur, blur(22px));
		box-shadow: 0 4px 24px rgb(0 0 0 / 0.07);
		padding-inline: 1rem;
	}

	.title-wrapper {
		overflow: clip;
		padding: 0.25rem;
		margin: -0.25rem;
		min-width: 0;
	}

	/* below the sidebar breakpoint the fixed hamburger overlays the pill's right
	   end — reserve room so search and the menu button never collide */
	@media (max-width: 49.99rem) {
		:global([data-has-sidebar]) .header {
			padding-inline-end: calc(var(--sl-menu-button-size) + 0.75rem);
		}
	}

	.right-group,
	.social-icons {
		gap: 1rem;
		align-items: center;
	}
	.header-preferences {
		gap: 0.125rem;
		align-items: center;
	}
	.social-icons::after {
		content: '';
		height: 2rem;
		border-inline-end: 1px solid var(--sl-color-gray-5);
	}

	/* ---- theme cycle + language popover -------------------------------- */
	.header-preference {
		position: relative;
	}
	.preference-control {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.375rem;
		min-height: 2.25rem;
		padding: 0.375rem 0.75rem;
		border: 0;
		border-radius: var(--ocx-radius-pill, 999px);
		background: transparent;
		color: var(--sl-color-gray-2);
		font: inherit;
		font-size: var(--sl-text-sm);
		font-weight: 500;
		line-height: 1;
		white-space: nowrap;
		cursor: pointer;
		transition: background-color 0.12s, color 0.12s;
	}
	.preference-control:hover,
	.preference-control[aria-expanded='true'] {
		background-color: var(--ocx-hover, rgba(128, 128, 128, 0.1));
		color: var(--sl-color-white);
	}
	.preference-control:focus:not(:focus-visible) {
		outline: none;
		box-shadow: none;
	}
	.preference-control:focus-visible {
		outline: 2px solid color-mix(in srgb, var(--sl-color-accent) 55%, transparent);
		outline-offset: 2px;
	}
	.preference-icon {
		display: inline-flex;
		font-size: 0.9rem;
	}
	.preference-icon[hidden] {
		display: none;
	}
	.preference-caret {
		font-size: 1rem;
		opacity: 0.55;
		transition: transform 0.15s ease;
	}
	.language-trigger[aria-expanded='true'] .preference-caret {
		transform: rotate(180deg);
	}
	.language-menu {
		position: absolute;
		top: calc(100% + 0.625rem);
		inset-inline-end: 0;
		min-width: 12rem;
		padding: 0.375rem;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: var(--ocx-radius, 12px);
		background-color: var(--ocx-glass-panel, canvas);
		backdrop-filter: var(--ocx-glass-blur, blur(22px));
		-webkit-backdrop-filter: var(--ocx-glass-blur, blur(22px));
		box-shadow: var(--ocx-shadow, 0 10px 28px rgba(0, 0, 0, 0.2));
		opacity: 0;
		visibility: hidden;
		translate: 0 -0.25rem;
		transition: opacity 0.16s ease, visibility 0.16s, translate 0.16s ease;
		z-index: var(--sl-z-index-navbar);
	}
	.language-preference:has(> .language-trigger[aria-expanded='true']) .language-menu {
		opacity: 1;
		visibility: visible;
		translate: 0 0;
	}
	.language-menu ul {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.language-menu a {
		display: block;
		padding: 0.5rem 0.75rem;
		border-radius: var(--ocx-radius-sm, 8px);
		color: var(--sl-color-gray-2);
		font-size: var(--sl-text-sm);
		text-decoration: none;
		transition: background-color 0.12s, color 0.12s;
	}
	.language-menu a:hover,
	.language-menu a:focus-visible,
	.language-menu a[aria-checked='true'] {
		background-color: var(--ocx-hover, rgba(128, 128, 128, 0.1));
		color: var(--sl-color-white);
	}
	.language-menu a:focus:not(:focus-visible) {
		outline: none;
	}

	@media (prefers-reduced-motion: reduce) {
		.preference-control,
		.preference-caret,
		.language-menu {
			transition: none;
		}
	}

	/* ---- hover-dropdown nav (desktop only) ---- */
	.glass-nav {
		display: none;
	}

	@media (min-width: 72rem) {
		.glass-nav {
			display: block;
		}
		.glass-nav > ul {
			display: flex;
			align-items: center;
			gap: 0.125rem;
			list-style: none;
			margin: 0;
			padding: 0;
		}
		.nav-item {
			position: relative;
		}
		.nav-link {
			display: inline-flex;
			align-items: center;
			gap: 0.375rem;
			padding: 0.375rem 0.875rem;
			border: 0;
			border-radius: var(--ocx-radius-pill, 999px);
			background: transparent;
			color: var(--sl-color-gray-2);
			font: inherit;
			font-size: var(--sl-text-sm);
			font-weight: 500;
			line-height: 1;
			text-decoration: none;
			cursor: pointer;
			white-space: nowrap;
			transition: background-color 0.12s, color 0.12s;
		}
		.nav-link svg { opacity: 0.55; transition: transform 0.15s; }
		.nav-item:hover .nav-link,
		.nav-item:focus-within .nav-link {
			background-color: var(--ocx-hover, rgba(128, 128, 128, 0.1));
			color: var(--sl-color-white);
		}
		.nav-item:hover .nav-link svg,
		.nav-item:focus-within .nav-link svg { transform: rotate(180deg); }

		.nav-drop {
			position: absolute;
			top: 100%;
			left: 50%;
			translate: -50% 0;
			padding-top: 0.625rem;
			opacity: 0;
			visibility: hidden;
			transition: opacity 0.16s ease, visibility 0.16s, translate 0.16s ease;
			z-index: var(--sl-z-index-navbar);
		}
		.nav-item:hover .nav-drop,
		.nav-item:focus-within .nav-drop,
		.nav-item:has(> .nav-link[aria-expanded='true']) .nav-drop {
			opacity: 1;
			visibility: visible;
			translate: -50% 0.25rem;
		}
		.nav-drop > ul {
			list-style: none;
			margin: 0;
			padding: 0.375rem;
			min-width: 15rem;
			border: 1px solid var(--sl-color-gray-5);
			border-radius: var(--ocx-radius, 12px);
			background-color: var(--ocx-glass-panel, canvas);
			backdrop-filter: var(--ocx-glass-blur, blur(22px));
			-webkit-backdrop-filter: var(--ocx-glass-blur, blur(22px));
			box-shadow: var(--ocx-shadow, 0 10px 28px rgba(0, 0, 0, 0.2));
		}
		.nav-drop a {
			display: block;
			padding: 0.5rem 0.75rem;
			border-radius: var(--ocx-radius-sm, 8px);
			color: var(--sl-color-gray-2);
			font-size: var(--sl-text-sm);
			text-decoration: none;
			transition: background-color 0.12s, color 0.12s;
		}
		.nav-drop a:hover,
		.nav-drop a:focus-visible {
			background-color: var(--ocx-hover, rgba(128, 128, 128, 0.1));
			color: var(--sl-color-white);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.nav-link svg,
		.nav-drop {
			transition: none;
		}
	}

	/* ---- splash hamburger (below the desktop-nav breakpoint) ---- */
	.lp-menu { display: none; position: relative; }
	@media (max-width: 71.99rem) {
		.lp-menu { display: block; }
	}
	.lp-menu-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.25rem;
		height: 2.25rem;
		border: 0;
		border-radius: var(--ocx-radius-pill, 999px);
		background: transparent;
		color: var(--sl-color-gray-2);
		cursor: pointer;
		transition: background-color 0.12s, color 0.12s;
	}
	.lp-menu-btn:hover,
	.lp-menu-btn[aria-expanded='true'] {
		background-color: var(--ocx-hover, rgba(128, 128, 128, 0.1));
		color: var(--sl-color-white);
	}
	.lp-menu-panel {
		position: absolute;
		top: calc(100% + 0.75rem);
		inset-inline-end: 0;
		min-width: 17rem;
		max-height: min(72dvh, 34rem);
		overflow-y: auto;
		padding: 0.875rem;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: var(--ocx-radius, 12px);
		background-color: var(--ocx-glass-panel, canvas);
		backdrop-filter: var(--ocx-glass-blur, blur(40px));
		-webkit-backdrop-filter: var(--ocx-glass-blur, blur(40px));
		box-shadow: var(--ocx-shadow, 0 10px 28px rgb(0 0 0 / 0.2));
		opacity: 0;
		visibility: hidden;
		translate: 0 -4px;
		transition: opacity 0.16s ease, visibility 0.16s, translate 0.16s ease;
		z-index: var(--sl-z-index-navbar);
	}
	.lp-menu:has(> .lp-menu-btn[aria-expanded='true']) .lp-menu-panel {
		opacity: 1;
		visibility: visible;
		translate: 0 0;
	}
	.lp-menu-group + .lp-menu-group { margin-top: 0.75rem; }
	.lp-menu-group > span {
		display: block;
		margin-bottom: 0.25rem;
		font-size: var(--sl-text-2xs);
		font-weight: 650;
		color: var(--sl-color-gray-3);
	}
	.lp-menu-group ul { list-style: none; margin: 0; padding: 0; }
	.lp-menu-group a,
	.lp-menu-contrib {
		display: block;
		padding: 0.4rem 0.5rem;
		border-radius: var(--ocx-radius-sm, 8px);
		color: var(--sl-color-gray-2);
		font-size: var(--sl-text-sm);
		text-decoration: none;
		transition: background-color 0.12s, color 0.12s;
	}
	.lp-menu-contrib { margin-top: 0.75rem; font-weight: 600; color: var(--sl-color-white); }
	.lp-menu-group a:hover,
	.lp-menu-group a:focus-visible,
	.lp-menu-contrib:hover,
	.lp-menu-contrib:focus-visible {
		background-color: var(--ocx-hover, rgba(128, 128, 128, 0.1));
		color: var(--sl-color-white);
	}
	@media (prefers-reduced-motion: reduce) {
		.lp-menu-panel { transition: none; }
	}
</style>

<script>
	// Click/Enter/Space toggles the dropdowns (hover and focus-within still work
	// via CSS); Escape or an outside click closes any open menu.
	const buttons = Array.from(
		document.querySelectorAll<HTMLButtonElement>(
			'.glass-nav .nav-link[aria-haspopup], .lp-menu-btn, .language-trigger',
		),
	);
	const closeAll = (except?: HTMLButtonElement) => {
		for (const b of buttons) if (b !== except) b.setAttribute('aria-expanded', 'false');
	};
	for (const btn of buttons) {
		btn.addEventListener('click', () => {
			const open = btn.getAttribute('aria-expanded') === 'true';
			closeAll(btn);
			btn.setAttribute('aria-expanded', String(!open));
		});
	}
	document.addEventListener('click', (e) => {
		if (!(e.target instanceof Element) || !e.target.closest('.glass-nav, .lp-menu, .header-preference')) closeAll();
	});
	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape') closeAll();
	});

	// The theme has three predictable states, so each activation advances the
	// stable Auto -> Light -> Dark order instead of opening another menu.
	type Theme = 'auto' | 'light' | 'dark';
	const themeOrder: Theme[] = ['auto', 'light', 'dark'];
	const storageKey = 'starlight-theme';
	const preferredTheme = () =>
		window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
	const loadTheme = (): Theme => {
		const stored = localStorage.getItem(storageKey);
		return stored === 'light' || stored === 'dark' ? stored : 'auto';
	};
	const updateThemeButton = (button: HTMLButtonElement, theme: Theme) => {
		const label = button.dataset[`${theme}Label`] ?? theme;
		button.dataset.themeValue = theme;
		button.querySelector<HTMLElement>('[data-theme-label]')!.textContent = label;
		for (const icon of button.querySelectorAll<HTMLElement>('[data-theme-icon]')) {
			icon.hidden = icon.dataset.themeIcon !== theme;
		}
		const themeName = button.dataset.themeName ?? 'Theme';
		button.title = `${themeName}: ${label}`;
		button.setAttribute('aria-label', `${themeName}: ${label}. ${button.dataset.cycleHint ?? ''}`.trim());
	};
	const applyTheme = (button: HTMLButtonElement, theme: Theme) => {
		document.documentElement.dataset.theme = theme === 'auto' ? preferredTheme() : theme;
		localStorage.setItem(storageKey, theme === 'auto' ? '' : theme);
		updateThemeButton(button, theme);
	};
	for (const button of document.querySelectorAll<HTMLButtonElement>('.theme-cycle')) {
		applyTheme(button, loadTheme());
		button.addEventListener('click', () => {
			const current = (button.dataset.themeValue as Theme | undefined) ?? 'auto';
			const next = themeOrder[(themeOrder.indexOf(current) + 1) % themeOrder.length] ?? 'auto';
			applyTheme(button, next);
		});
	}
	window.matchMedia('(prefers-color-scheme: light)').addEventListener('change', () => {
		if (loadTheme() !== 'auto') return;
		for (const button of document.querySelectorAll<HTMLButtonElement>('.theme-cycle')) {
			applyTheme(button, 'auto');
		}
	});

	// Arrow keys move directly through language links; Escape returns focus to
	// the trigger so keyboard navigation behaves like the other header menus.
	for (const trigger of document.querySelectorAll<HTMLButtonElement>('.language-trigger')) {
		const menu = trigger.parentElement?.querySelector<HTMLElement>('.language-menu');
		const items = Array.from(menu?.querySelectorAll<HTMLAnchorElement>('a[role^="menuitem"]') ?? []);
		trigger.addEventListener('keydown', (event) => {
			if (event.key !== 'ArrowDown' && event.key !== 'ArrowUp') return;
			event.preventDefault();
			closeAll(trigger);
			trigger.setAttribute('aria-expanded', 'true');
			const target = items[event.key === 'ArrowDown' ? 0 : items.length - 1];
			// The popover intentionally transitions `visibility`; Chromium refuses
			// to focus descendants until that transition has made them visible.
			const focusWhenVisible = (attempt = 0) => {
				if (!target || !menu || trigger.getAttribute('aria-expanded') !== 'true') return;
				if (getComputedStyle(menu).visibility === 'visible') {
					target.focus();
					return;
				}
				if (attempt < 20) requestAnimationFrame(() => focusWhenVisible(attempt + 1));
			};
			focusWhenVisible();
		});
		menu?.addEventListener('keydown', (event) => {
			const activeIndex = items.indexOf(document.activeElement as HTMLAnchorElement);
			if (event.key === 'Escape') {
				event.preventDefault();
				trigger.setAttribute('aria-expanded', 'false');
				trigger.focus();
				return;
			}
			if (!['ArrowDown', 'ArrowUp', 'Home', 'End'].includes(event.key)) return;
			event.preventDefault();
			const nextIndex =
				event.key === 'Home' ? 0 :
				event.key === 'End' ? items.length - 1 :
				event.key === 'ArrowDown' ? (activeIndex + 1) % items.length :
				(activeIndex - 1 + items.length) % items.length;
			items[nextIndex]?.focus();
		});
	}
</script>
