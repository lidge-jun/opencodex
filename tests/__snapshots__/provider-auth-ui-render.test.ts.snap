// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`provider auth UI rendering renders separate OAuth and API summary regions 1`] = `"<div class="prov-auth-grid"><section class="panel panel-accent prov-accounts-panel" aria-labelledby="oauth-providers-title"><div class="prov-accounts-head"><div><div class="row"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;color:var(--accent)"><rect x="4" y="11" width="16" height="10" rx="2"></rect><path d="M8 11V7a4 4 0 0 1 8 0v4"></path></svg><h3 id="oauth-providers-title" class="text-subtitle">OAuth</h3></div><p class="muted text-label leading-body" style="margin:5px 0 0">Connected accounts</p></div></div><div class="oauth-grid"><div class="oauth-row" data-provider-id="xai">xAI (Grok)</div></div><button type="button" class="prov-account-add-tile" aria-label="Connect account provider"><span class="prov-account-add-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"></path></svg></span><span class="prov-account-add-copy"><span class="font-semibold">Connect account provider</span><span class="muted text-label">Find another account provider</span></span></button></section><section class="panel panel-accent prov-accounts-panel" aria-labelledby="api-providers-title"><div class="prov-accounts-head"><div><div class="row"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;color:var(--accent)"><rect x="4" y="11" width="16" height="10" rx="2"></rect><path d="M8 11V7a4 4 0 0 1 8 0v4"></path></svg><h3 id="api-providers-title" class="text-subtitle">API Providers</h3></div><p class="muted text-label leading-body" style="margin:5px 0 0">Configured keys</p></div></div><div class="oauth-grid"></div><div class="prov-accounts-empty muted text-control">No API providers configured yet.</div><button type="button" class="prov-account-add-tile" aria-label="Add API provider"><span class="prov-account-add-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"></path></svg></span><span class="prov-account-add-copy"><span class="font-semibold">Add API provider</span><span class="muted text-label">Choose a provider</span></span></button></section></div>"`;

exports[`provider auth UI rendering renders only unconfigured API-key-capable catalog entries 1`] = `"<div class="provider-catalog"><div class="provider-catalog-accounts-hint muted text-label">Choose an API-key provider, then enter its key and endpoint settings.</div><input type="search" class="input provider-catalog-search" placeholder="Search providers…" aria-label="Search providers…" value=""/><div class="provider-catalog-rows"><button class="list-row"><div><div class="title">xAI (Grok)</div><div class="sub"><code class="chip">openai-chat</code></div></div><div class="provider-catalog-badges"><span class="badge badge-muted">API key</span></div></button></div><div class="provider-catalog-footer"><div style="flex:1"></div><button class="link-btn">Provider not listed? Add a custom one</button></div></div>"`;
